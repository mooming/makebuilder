digraph MakeBuilder {
  rankdir=LR;
  node [shape=box, style=rounded];
  edge [arrowhead=vee];

  "MakeBuilder" [label="MakeBuilder\n(None)", style=filled, fillcolor=white];
  "Application" [label="Application\n(None)", style=filled, fillcolor=white];
  "makebuild" [label="makebuild\n(Executable)", style=filled, fillcolor=lightgreen];
  "Source" [label="Source\n(None)", style=filled, fillcolor=white];
  "Common" [label="Common\n(StaticLibrary)", style=filled, fillcolor=lightblue];
  "TestCases" [label="TestCases\n(None)", style=filled, fillcolor=white];
  "DependencyGraphTest" [label="DependencyGraphTest\n(None)", style=filled, fillcolor=white];
  "GraphApp" [label="GraphApp\n(Executable)", style=filled, fillcolor=lightgreen];
  "GraphLib" [label="GraphLib\n(HeaderOnly)", style=filled, fillcolor=lightyellow];
  "03_header_only" [label="03_header_only\n(HeaderOnly)", style=filled, fillcolor=lightyellow];
  "TestProject" [label="TestProject\n(None)", style=filled, fillcolor=white];
  "MultiConfigApp" [label="MultiConfigApp\n(Executable)", style=filled, fillcolor=lightgreen];
  "TestProject" [label="TestProject\n(None)", style=filled, fillcolor=white];
  "AppWithLib" [label="AppWithLib\n(Executable)", style=filled, fillcolor=lightgreen];
  "TestProject" [label="TestProject\n(None)", style=filled, fillcolor=white];
  "SimpleApp" [label="SimpleApp\n(Executable)", style=filled, fillcolor=lightgreen];
  "makebuild" -> "Common";
  "GraphApp" -> "GraphLib";
}
